    // ===== HELPERS =====
    function fmt(t) { if (!t) return ''; let s = escapeHtml(t); s = s.replace(/https?:\/\/[^\s<>"{}|\\^`\[\]]+/gi, u => `<a href="${u}" target="_blank">${u.length>30?u.slice(0,27)+'...':u}</a>`); return s; }
    function formatBlock(t) { if (!t) return ''; return t.split(/(?=Berikut|Contoh|Perhitungan)/gi).filter(x=>x.trim()).map(x=>`<span style="display:block;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid var(--lc-border)">${x.trim().replace(/\n/g,'<br>')}</span>`).join('') || t.replace(/\n/g,'<br>'); }
    function formatResult(t) { if (!t) return ''; return t.split(/\n+/).filter(l=>l.trim()).map(l => l.replace(/(\d+(?:\.\d+)?(?:%| x |\+|\-|\=))/gi,'<span class="hl2">$1</span>').replace(/(key|Key|modal|Modal|diskon|Diskon|Hadiah|hadiah)/gi,'<span class="hl">$1</span>')).join('<br><br>'); }
    function escapeHtml(t) { if (!t) return ''; const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
    function fallbackCopy(t) { const ta = document.createElement('textarea'); ta.value = t; ta.style.cssText = 'position:fixed;left:-9999px'; document.body.appendChild(ta); ta.select(); try { document.execCommand('copy'); toast('✅ Disalin'); } catch { toast('❗ Gagal'); } document.body.removeChild(ta); }
    async function copyText(t, el) { let f = t; try { f = decodeURIComponent(t); } catch {} const clean = f.replace(/<[^>]*>/g,'').replace(/&nbsp;/g,' '); try { await navigator.clipboard.writeText(clean); toast('✅ Disalin'); if (el) { el.classList.add('copied'); setTimeout(()=>el.classList.remove('copied'),350); } } catch { toast('❗ Gagal'); } }
    function formatNum(n) { return new Intl.NumberFormat('id-ID').format(n); }
    function safeGet(row, idx) { return row && row[idx] !== undefined ? row[idx] : ''; }

    // ===== SEARCH =====
    function doSearch(q) {
        q = q.toLowerCase().trim();
        if (activeTab === 'kendala') { filtered.kendala = data.kendala.filter(x => x.judul.toLowerCase().includes(q) || [x.j1,x.j2,x.j3].some(y=>y?.toLowerCase().includes(q))); renderKendala(filtered.kendala); document.getElementById('lc-count').textContent = filtered.kendala.length; }
        else if (activeTab === 'foto') { filtered.foto = data.foto.filter(x => x.judul.toLowerCase().includes(q)); renderFoto(filtered.foto); document.getElementById('lc-count').textContent = filtered.foto.length; }
