    // ===== DRAG =====
    function makeDraggable(el, handle, onSave) {
        let down = false, sx, sy, sl, st;
        handle.onmousedown = e => {
            if (e.target.closest('.hdr-btn') || e.target.closest('.tab') || e.target.closest('.chip')) return;
            down = true; sx = e.clientX; sy = e.clientY; sl = el.offsetLeft; st = el.offsetTop;
            el.style.transition = 'none'; e.preventDefault();
        };
        document.onmousemove = e => {
            if (!down) return;
            const nw = Math.max(10, Math.min(sl + e.clientX - sx, window.innerWidth - 50));
            const nh = Math.max(10, Math.min(st + e.clientY - sy, window.innerHeight - 50));
            el.style.left = nw + 'px'; el.style.top = nh + 'px';
        };
        document.onmouseup = () => { if (down) { down = false; el.style.transition = ''; if (onSave) onSave({ x: el.offsetLeft, y: el.offsetTop }); } };
    }

    // ===== DATA LOAD =====
    function loadJSON(url, fallback) {
        return new Promise(resolve => {
            GM_xmlhttpRequest({ method: 'GET', url, timeout: 8000,
                onload: res => {
                    try {
                        const m = res.responseText.match(/google\.visualization\.Query\.setResponse\(([\s\S]*)\);?/);
                        if (!m) throw new Error('Parse fail');
                        const rows = JSON.parse(m[1]).table?.rows || [];
                        resolve(rows.map(r => { const c = r.c || []; return { judul: c[0]?.v?.toString().trim()||'', j1: c[1]?.v?.toString().trim()||'', j2: c[2]?.v?.toString().trim()||'', j3: c[3]?.v?.toString().trim()||'' }; }).filter(x => x.judul));
                    } catch { resolve(fallback); }
                }, onerror: () => resolve(fallback)
            });
        });
    }
    function loadCSV(url, fallback) {
        return new Promise(resolve => {
            GM_xmlhttpRequest({ method: 'GET', url, timeout: 8000,
                onload: res => {
                    try {
                        const rows = parseCSV(res.responseText);
                        resolve(rows);
                    } catch { resolve(fallback); }
                }, onerror: () => resolve(fallback)
            });
        });
    }
    function parseCSV(text) {
        let p = [], row = [], entry = '', st = 0;
        for (let i = 0; i < text.length; i++) {
            const c = text[i], n = text[i+1];
            if (st === 0) {
                if (c === '"') st = 1;
                else if (c === ',') { row.push(entry); entry = ''; }
                else if (c === '\r' && n === '\n') { row.push(entry); p.push(row); row = []; entry = ''; i++; }
                else if (c === '\n' || c === '\r') { row.push(entry); p.push(row); row = []; entry = ''; }
                else entry += c;
            } else if (st === 1) {
                if (c === '"' && n === '"') { entry += '"'; i++; }
                else if (c === '"') st = 0; else entry += c;
            }
        }
        if (entry || row.length) { row.push(entry); p.push(row); }
        return p;
    }

