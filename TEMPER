    // ===== LOAD DATA FUNCTIONS =====
    async function loadPrediksiData() {
        try {
            // Tambahkan timestamp agar tidak cache
            const rows = parseCSV(await (await fetch(CONFIG.sheets.prediksi + '&t=' + Date.now())).text());
            data.prediksi = []; data.jadwal = []; data.link = [];

            // Parsing sederhana (sesuaikan dengan struktur sheet Anda)
            // Asumsi: Baris 1 = Tanggal, Kolom B-J = Prediksi, Kolom K-S = Jadwal, dst.
            if (rows[0]) {
                const rawDate = safeGet(rows[0],1);
                if (rawDate) {
                     // Coba parse tanggal dari sheet jika ada
                     const p = rawDate.split('/');
                     if (p.length === 3) currentDate = `${p[2]}-${p[0].padStart(2,'0')}-${p[1].padStart(2,'0')}`;
                }
            }

            // Ambil data prediksi (contoh range baris 2-84 kolom 1)
            for (let i = 2; i <= 84 && i < rows.length; i++) {
                const t = safeGet(rows[i],1);
                if (t) data.prediksi.push({ title: t.split(/[\s,]+/)[0], content: t, type: 'prediksi' });
            }
            // Ambil data jadwal (contoh range baris 2-55 kolom 2)
            for (let i = 2; i <= 55 && i < rows.length; i++) {
                const t = safeGet(rows[i],2);
                if (t) data.jadwal.push({ title: t.split(/[\s,]+/)[0], content: t, type: 'jadwal' });
            }
            // Ambil data link (contoh range baris 56-82 kolom 2)
            for (let i = 56; i <= 82 && i < rows.length; i++) {
                const t = safeGet(rows[i],2);
                if (t) data.link.push({ title: t.split(/[\s,]+/)[0], content: t, type: 'link' });
            }

            if (activeTab === 'prediksi') renderPrediksi('prediksi', [...data.prediksi, ...data.jadwal, ...data.link]);
        } catch(e) { console.error('Load prediksi error:', e); }
    }

    async function loadAllData() {
        // Kendala
        const kd = await loadJSON(CONFIG.sheets.kendala, FALLBACK.kendala);
        data.kendala = kd; filtered.kendala = [...kd];
        if (activeTab === 'kendala') renderKendala(filtered.kendala);

        // Foto
        const ft = await loadJSON(CONFIG.sheets.foto, FALLBACK.foto).then(rows => rows.map(r => ({ judul: r.judul, foto: r.j1 })));
        data.foto = ft; filtered.foto = [...ft];
        if (activeTab === 'foto') renderFoto(filtered.foto);

        // Prediksi (dengan tanggal)
        await loadPrediksiData();

        // Hitung
        try {
            const rows = parseCSV(await (await fetch(CONFIG.sheets.hitung + '&t=' + Date.now())).text());
            if (rows[0]) { const nom = safeGet(rows[0],23); if (nom) { data.hitung.nominal = nom; if (activeTab === 'hitung') { document.getElementById('h-nom').value = nom; document.getElementById('h-status').textContent = 'Rp ' + formatNum(nom); } } }
            const secDef = [{ tRow:0,tCol:24,start:2,end:42,title:'SEMUA'},{tRow:43,tCol:24,start:45,end:80,title:'MACAU 4D'},{tRow:81,tCol:24,start:83,end:119,title:'MACAU 5D'},{tRow:120,tCol:24,start:122,end:153,title:'KINGKONG'},{tRow:154,tCol:24,start:156,end:179,title:'BONUS'},{tRow:180,tCol:24,start:182,end:213,title:'JAKARTA'},{tRow:215,tCol:24,start:217,end:248,title:'TOTOMALI'},{tRow:249,tCol:24,start:251,end:282,title:'HOKIDRAW'},{tRow:283,tCol:24,start:285,end:316,title:'SYDNEY/HK' }];
            data.kelompok = {};
            secDef.forEach(sec => { const items = []; for (let i = sec.start; i <= sec.end && i < rows.length; i++) { if (rows[i]) { const l = safeGet(rows[i],23), v = safeGet(rows[i],24); if (l || v) items.push({ label: l || '-', value: v || '-' }); } } if (items.length > 0) data.kelompok[sec.title] = items; });
            if (activeTab === 'hitung') { updateLabelChips(); if (selectedTipe && selectedLabel) showResult(); }
        } catch {}

        // Update counts
        if (activeTab === 'kendala') document.getElementById('lc-count').textContent = filtered.kendala.length;
        else if (activeTab === 'foto') document.getElementById('lc-count').textContent = filtered.foto.length;
        else if (activeTab === 'prediksi') document.getElementById('lc-count').textContent = data.prediksi.length + data.jadwal.length + data.link.length;
    }

    // ===== INIT =====
    async function init() {
        const { fab, popup, toast: t, lb } = createUI();
        let minimized = false, isOpen = false;

        const toggle = () => { isOpen = !isOpen; popup.classList.toggle('active', isOpen); fab.classList.toggle('active', !isOpen); document.body.style.overflow = isOpen ? 'hidden' : ''; if (isOpen && data.kendala.length === 0) loadAllData(); };

        fab.onclick = toggle;
        document.getElementById('lc-close').onclick = toggle;
        document.getElementById('lc-min').onclick = () => { minimized = !minimized; popup.style.height = minimized ? '42px' : CONFIG.popup.h + 'px'; popup.querySelector('.tabs').style.display = minimized ? 'none' : ''; popup.querySelector('.toolbar').style.display = minimized ? 'none' : ''; popup.querySelectorAll('.content').forEach(c => c.style.display = minimized ? 'none' : ''); };
        document.querySelectorAll('#lc-popup .tab').forEach(tab => tab.onclick = () => switchTab(tab.dataset.tab));
        document.getElementById('lc-search').oninput = e => doSearch(e.target.value);
        makeDraggable(popup, document.getElementById('lc-hdr'), pos => GM_setValue('lcPos', pos));

        // Lightbox events
        lb.querySelector('.lb-close').onclick = closeLightbox;
        document.getElementById('lb-prev').onclick = () => navLightbox(-1);
        document.getElementById('lb-next').onclick = () => navLightbox(1);
        document.getElementById('lb-copy').onclick = copyLightbox;
        lb.onclick = e => { if (e.target === lb) closeLightbox(); };

        // Keyboard
        document.onkeydown = e => { if (e.ctrlKey && e.shiftKey && e.key.toLowerCase() === 'k') { e.preventDefault(); toggle(); } if (e.key === 'Escape') closeLightbox(); };

        // Menu
        if (typeof GM_registerMenuCommand === 'function') {
            GM_registerMenuCommand('🔷 Buka Menu', toggle);
            GM_registerMenuCommand('🗑️ Reset Posisi', () => { GM_setValue('lcPos', CONFIG.popup); toast('📍 Posisi direset'); location.reload(); });
        }

        // Load initial data
        loadAllData();
        console.log('🔷 ALL-IN-ONE v12.0 Ready!');
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init); else init();

})();
