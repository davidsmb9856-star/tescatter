    // ============================================
    // Core processing (filter chat)
    // ============================================
    function processTextNode(textNode) {
        if (!enableToggle.checked || !textNode.nodeValue || !textNode.nodeValue.trim()) return;
        if (textNode.parentNode.closest('.lc-pro-panel, .lc-pro-toggle, .lc-pro-toast, .lc-pro-highlight, .lc-pro-iframe-panel, .lc-pro-debug-modal')) return;

        const coarseWords = getWords('coarse');
        const importantWords = getWords('important');
        if (coarseWords.length === 0 && importantWords.length === 0) return;

        const escapeRegExp = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        let allWords = [];
        coarseWords.forEach(w => allWords.push({ word: w, type: 'lc-pro-coarse' }));
        importantWords.forEach(w => allWords.push({ word: w, type: 'lc-pro-important' }));
        allWords.sort((a, b) => b.word.length - a.word.length);

        const pattern = allWords.map(w => escapeRegExp(w.word)).join('|');
        if (!pattern) return;

        const regex = new RegExp(`(${pattern})`, 'gi');
        const text = textNode.nodeValue;
        if (!regex.test(text)) return;
        regex.lastIndex = 0;

        const fragment = document.createDocumentFragment();
        let lastIndex = 0, match, hasMatch = false;
        while ((match = regex.exec(text)) !== null) {
            hasMatch = true;
            if (match.index > lastIndex) fragment.appendChild(document.createTextNode(text.substring(lastIndex, match.index)));
            const matchedWord = match[0];
            const wordObj = allWords.find(w => w.word.toLowerCase() === matchedWord.toLowerCase());
            const span = document.createElement('span');
            span.className = `lc-pro-highlight ${wordObj.type}`;
            span.textContent = matchedWord;
            fragment.appendChild(span);
            lastIndex = regex.lastIndex;
        }
        if (hasMatch) {
            if (lastIndex < text.length) fragment.appendChild(document.createTextNode(text.substring(lastIndex)));
            if (textNode.parentNode) textNode.parentNode.replaceChild(fragment, textNode);
        }
    }

    function scanAllText() {
        clearAllHighlights();
        const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
        const nodesToProcess = [];
        let node, count = 0;
        while ((node = walker.nextNode()) && count < 2000) {
            if (!node.parentNode.closest('.lc-pro-panel, .lc-pro-toggle, .lc-pro-toast, .lc-pro-iframe-panel, .lc-pro-debug-modal')) nodesToProcess.push(node);
            count++;
        }
        nodesToProcess.forEach(processTextNode);
    }

    const observer = new MutationObserver((mutations) => {
        mutations.forEach(mutation => {
            if (mutation.type === 'childList') {
                mutation.addedNodes.forEach(node => {
                    if (node.nodeType === Node.TEXT_NODE) pendingNodes.add(node);
                    else if (node.nodeType === Node.ELEMENT_NODE) {
                        if (node.closest('.lc-pro-panel, .lc-pro-toggle, .lc-pro-toast, .lc-pro-highlight, .lc-pro-iframe-panel, .lc-pro-debug-modal')) return;
                        const walker = document.createTreeWalker(node, NodeFilter.SHOW_TEXT, null, false);
                        let textNode;
                        while ((textNode = walker.nextNode())) pendingNodes.add(textNode);
                    }
                });
            }
        });
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            if (pendingNodes.size === 0) return;
            const nodesArray = Array.from(pendingNodes);
            pendingNodes.clear();
            nodesArray.slice(0, CONFIG.maxNodesPerBatch).forEach(processTextNode);
            if (nodesArray.length > CONFIG.maxNodesPerBatch) {
                nodesArray.slice(CONFIG.maxNodesPerBatch).forEach(n => pendingNodes.add(n));
                debounceTimer = setTimeout(() => {}, 50);
            }
        }, CONFIG.debounceTime);
    });

    setTimeout(() => {
        if (enableToggle.checked) scanAllText();
        try { observer.observe(document.body, { childList: true, subtree: true }); }
        catch (e) { console.log('Observer failed, retrying...', e); }
    }, 1500);

    console.log('[LiveChat Pro] Smart Panel v9.9 Loaded - Google Sheets Support Added');
    showToast('LiveChat Pro v9.9 siap digunakan!', 'success');

})();
