    // ============================================
    // HTML Modification & Proxy Injection
    // ============================================
    function modifyHtml(html, url) {
        const urlObj = new URL(url);
        const baseUrl = urlObj.origin + urlObj.pathname.substring(0, urlObj.pathname.lastIndexOf('/') + 1);

        // Handle FRAMESET (Admin Panel)
        if (/<frameset/i.test(html)) {
            console.log('[LiveChat Pro] Converting <frameset> to HTML5 layout...');
            const frameRegex = /<frame[^>]+src=["']([^"']+)["'][^>]*>/gi;
            const frames = [];
            let match;
            while ((match = frameRegex.exec(html)) !== null) {
                frames.push(match[1]);
            }

            if (frames.length > 0) {
                const framesetMatch = html.match(/<frameset([^>]*)>/i);
                const attrs = framesetMatch ? framesetMatch[1] : '';
                const rowsMatch = attrs.match(/rows=["']([^"']+)["']/i);
                const colsMatch = attrs.match(/cols=["']([^"']+)["']/i);

                let iframesHtml = '';
                if (frames.length === 3) {
                    const topSrc = frames[0];
                    const leftSrc = frames[1];
                    const mainSrc = frames[2];
                    const topHeight = rowsMatch ? rowsMatch[1].split(',')[0].trim() : '40px';
                    const leftWidth = colsMatch ? colsMatch[1].split(',')[0].trim() : '200px';

                    iframesHtml = `
                        <iframe data-src="${topSrc}" style="width:100%;height:${topHeight};border:0;display:block;" name="jalanmaster"></iframe>
                        <div style="display:flex;height:calc(100% - ${topHeight});">
                            <iframe data-src="${leftSrc}" style="width:${leftWidth};height:100%;border:0;display:block;" name="menu"></iframe>
                            <iframe data-src="${mainSrc}" style="flex:1;height:100%;border:0;display:block;" name="master"></iframe>
                        </div>
                    `;
                } else {
                    iframesHtml = frames.map((src, i) =>
                        `<iframe data-src="${src}" style="width:100%;flex:1;border:0;display:block;" name="frame${i}"></iframe>`
                    ).join('');
                    iframesHtml = `<div style="display:flex;flex-direction:column;height:100%;">${iframesHtml}</div>`;
                }

                html = `<!DOCTYPE html><html><head><base href="${baseUrl}"></head><body style="margin:0;padding:0;height:100%;overflow:hidden;background:#fff;">
                    ${iframesHtml}
                    <script>
                        document.querySelectorAll('iframe[data-src]').forEach((iframe, index) => {
                            const url = iframe.getAttribute('data-src');
                            const id = 'frame_' + index + '_' + Math.random().toString(36).substring(7);

                            const listener = (event) => {
                                if (event.data && event.data.type === 'lc-pro-frame-html' && event.data.id === id) {
                                    window.removeEventListener('message', listener);
                                    try {
                                        const doc = iframe.contentDocument || iframe.contentWindow.document;
                                        doc.open();
                                        doc.write(event.data.html);
                                        doc.close();
                                    } catch(e) { console.error('[LiveChat Pro] Failed to write inner frame', e); }
                                }
                            };
                            window.addEventListener('message', listener);

                            window.parent.postMessage({
                                type: 'lc-pro-fetch-frame',
                                id: id,
                                url: new URL(url, document.baseURI).href
                            }, '*');
                        });
                    <\/script>
                </body></html>`;
                return html;
            }
        }

        // Inject <base> tag
        const baseTag = `<base href="${baseUrl}">`;
        if (!/<base[^>]*>/i.test(html)) {
            html = html.replace(/<head([^>]*)>/i, `<head$1>${baseTag}`);
            if (!html.includes(baseTag)) {
                html = html.replace(/<html([^>]*)>/i, `<html$1><head>${baseTag}</head>`);
            }
        }

        // Inject CSS Fix & AJAX Proxy Script
        const fixAndProxy = `
        <style>
            html.js body * { visibility: visible !important; }
            body { background: #fff !important; color: #000 !important; }
            .hidden, .hide, .collapse, .closed { display: revert !important; visibility: visible !important; height: auto !important; overflow: visible !important; }
        </style>
        <script>
            document.documentElement.classList.remove('no-js');
            document.documentElement.classList.add('js');

            // Tipu situs agar mengira dia tidak di dalam iframe (PENTING untuk Google Sheets)
            try {
                Object.defineProperty(window, 'top', { get: () => window, configurable: true });
                Object.defineProperty(window, 'parent', { get: () => window, configurable: true });
                Object.defineProperty(window, 'frameElement', { get: () => null, configurable: true });

                // Override window.open agar tetap di panel
                const _origOpen = window.open;
                window.open = function(url, name, specs) {
                    if (url && typeof url === 'string') {
                        try {
                            window.parent.postMessage({ type: 'lc-pro-navigate', url: new URL(url, document.baseURI).href }, '*');
                            return null;
                        } catch(e) {}
                    }
                    return _origOpen.apply(this, arguments);
                };
            } catch(e) {}

            window.fetch = function(url, options) {
                return new Promise((resolve, reject) => {
                    const id = 'f_' + Math.random().toString(36).substring(7);
                    const reqUrl = new URL(url, document.baseURI || window.location.href).href;

                    let headers = {};
                    if (options && options.headers) {
                        if (options.headers instanceof Headers) {
                            options.headers.forEach((value, key) => { headers[key] = value; });
                        } else if (typeof options.headers === 'object') {
                            headers = Object.assign({}, options.headers);
                        }
                    }

                    const listener = (event) => {
                        if (event.data && event.data.type === 'lc-pro-ajax-res' && event.data.id === id) {
                            window.removeEventListener('message', listener);
                            resolve({
                                ok: event.data.status >= 200 && event.data.status < 300,
                                status: event.data.status,
                                text: () => Promise.resolve(event.data.text),
                                json: () => Promise.resolve(JSON.parse(event.data.text)),
                                headers: new Headers()
                            });
                        }
                    };
                    window.addEventListener('message', listener);

                    window.parent.postMessage({
                        type: 'lc-pro-ajax-req',
                        id: id,
                        method: (options && options.method) || 'GET',
                        url: reqUrl,
                        body: options && options.body,
                        headers: headers
                    }, '*');
                });
            };

            const origXhrOpen = XMLHttpRequest.prototype.open;
            const origXhrSend = XMLHttpRequest.prototype.send;
            const origXhrSetRequestHeader = XMLHttpRequest.prototype.setRequestHeader;

            XMLHttpRequest.prototype.open = function(method, url) {
                this._pm = method;
                this._pu = new URL(url, document.baseURI || window.location.href).href;
                this._headers = {};
                return origXhrOpen.apply(this, arguments);
            };

            XMLHttpRequest.prototype.setRequestHeader = function(name, value) {
                if (!this._headers) this._headers = {};
                this._headers[name] = value;
                return origXhrSetRequestHeader.apply(this, arguments);
            };

            XMLHttpRequest.prototype.send = function(body) {
                const xhr = this;
                const id = 'x_' + Math.random().toString(36).substring(7);

                const listener = (event) => {
                    if (event.data && event.data.type === 'lc-pro-ajax-res' && event.data.id === id) {
                        window.removeEventListener('message', listener);
                        try {
                            Object.defineProperty(xhr, 'status', { value: event.data.status, writable: true });
                            Object.defineProperty(xhr, 'responseText', { value: event.data.text, writable: true });
                            Object.defineProperty(xhr, 'readyState', { value: 4, writable: true });
                            if (xhr.onreadystatechange) xhr.onreadystatechange();
                            if (xhr.onload) xhr.onload();
                        } catch(e) {}
                    }
                };
                window.addEventListener('message', listener);

                window.parent.postMessage({
                    type: 'lc-pro-ajax-req',
                    id: id,
                    method: xhr._pm || 'GET',
                    url: xhr._pu || window.location.href,
                    body: body,
                    headers: xhr._headers || {}
                }, '*');
            };

            document.addEventListener('click', function(e) {
                const link = e.target.closest('a');
                if (link && link.href && !link.href.startsWith('javascript:')) {
                    e.preventDefault();
                    window.parent.postMessage({ type: 'lc-pro-navigate', url: link.href }, '*');
                }
            }, true);
        <\/script>`;

        html = html.replace(/<\/head>/i, fixAndProxy + '</head>');
        if (!html.includes(fixAndProxy)) {
            html = fixAndProxy + html;
        }

        return html;
    }

