        } else {
            stopAutoRefresh();
            autoRefreshIndicator.style.display = 'none';
        }

        try {
            // For Google Sheets, use direct iframe src instead of doc.write
            // because Google Sheets has strict CSP and requires proper origin
            if (isGoogleSheets(url)) {
                console.log('[LiveChat Pro] Loading Google Sheets directly...');

                // Use embed URL for better iframe compatibility
                const embedUrl = url.replace('/edit', '/embed');

                // Try direct src first (works if user is logged in to Google)
                iframe.src = url;

                // Fallback: if direct loading fails due to X-Frame-Options,
                // show a message to open in new tab
                setTimeout(() => {
                    iframeLoader.classList.add('hidden');
                    console.log('[LiveChat Pro] Google Sheets loaded');
                }, 2000);

                return;
            }

            const response = await new Promise((resolve, reject) => {
                GM_xmlhttpRequest({
                    method: 'GET',
                    url: url,
                    anonymous: false,
                    headers: {
                        'Referer': url,
                        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
                        'User-Agent': navigator.userAgent
                    },
                    onload: (res) => {
                        if (res.status >= 200 && res.status < 300) resolve(res.responseText);
                        else reject(new Error(`HTTP ${res.status}: ${res.statusText}`));
                    },
                    onerror: (err) => reject(new Error('Network Error')),
                    timeout: 15000
                });
            });

            lastFetchedHtml = response;
            console.log('[LiveChat Pro] Fetch success. Length:', response.length);

            const modifiedHtml = modifyHtml(response, url);

            iframe.src = 'about:blank';

            setTimeout(() => {
                if (renderInIframe(modifiedHtml)) {
                    iframeLoader.classList.add('hidden');
                    console.log('[LiveChat Pro] HTML rendered via doc.write dengan AJAX Proxy aktif!');
                } else {
                    iframe.srcdoc = modifiedHtml;
                    iframeLoader.classList.add('hidden');
                }
            }, 100);

        } catch (error) {
            console.error('[LiveChat Pro] Fetch failed:', error);
            iframeLoader.classList.add('hidden');
            iframeError.classList.add('show');
            iframeErrorMsg.textContent = `Gagal mengambil data: ${error.message}. Pastikan Anda sudah login di situs tersebut di tab browser yang sama.`;
            showToast('Gagal memuat panel', 'error');
        }
    }

