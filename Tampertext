    function makeDraggable(element, handle, storageKey, options = {}) {
        let isDragging = false, startX, startY, initLeft, initTop, hasMoved = false;
        const onMouseDown = (e) => {
            if (e.target.closest('.lc-pro-close, .lc-pro-iframe-btn')) return;
            isDragging = true; hasMoved = false; element.classList.add('dragging');
            const rect = element.getBoundingClientRect(); startX = e.clientX; startY = e.clientY;
            initLeft = rect.left; initTop = rect.top; e.preventDefault();
        };
        const onMouseMove = (e) => {
            if (!isDragging) return; hasMoved = true;
            element.style.left = `${Math.max(0, Math.min(initLeft + (e.clientX - startX), window.innerWidth - element.offsetWidth))}px`;
            element.style.top = `${Math.max(0, Math.min(initTop + (e.clientY - startY), window.innerHeight - element.offsetHeight))}px`;
            element.style.right = 'auto';
        };
        const onMouseUp = () => {
            if (!isDragging) return; isDragging = false; element.classList.remove('dragging');
            if (hasMoved && storageKey) {
                const rect = element.getBoundingClientRect();
                localStorage.setItem(storageKey, JSON.stringify({ x: rect.left, y: rect.top }));
            }
            if (!hasMoved && options.onClick) options.onClick();
        };
        handle.addEventListener('mousedown', onMouseDown);
        document.addEventListener('mousemove', onMouseMove);
        document.addEventListener('mouseup', onMouseUp);
    }

