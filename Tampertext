    // ============================================
    // Export to CSV
    // ============================================
    function exportToCSV() {
        try {
            const iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
            const table = iframeDoc.querySelector('table');

            if (!table) {
                showToast('Tidak ada tabel untuk diekspor', 'error');
                return;
            }

            let csv = [];
            const rows = table.querySelectorAll('tr');

            rows.forEach(row => {
                const cols = row.querySelectorAll('td, th');
                const rowData = [];
                cols.forEach(col => {
                    let text = col.innerText.replace(/"/g, '""');
                    rowData.push(`"${text}"`);
                });
                csv.push(rowData.join(','));
            });

            const csvString = csv.join('\n');
            const blob = new Blob([csvString], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);

            link.setAttribute('href', url);
            link.setAttribute('download', `export_${new Date().getTime()}.csv`);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            showToast('Data berhasil diekspor', 'success');
        } catch (e) {
            console.error('[LiveChat Pro] Export failed:', e);
            showToast('Gagal mengekspor data', 'error');
        }
    }

    // ============================================
    // Message listener for AJAX proxy & navigation
    // ============================================
    window.addEventListener('message', async (event) => {
        // Handle AJAX Request from iframe
        if (event.data && event.data.type === 'lc-pro-ajax-req') {
            const { id, method, url, body, headers: origHeaders } = event.data;

            let nativeBody = body;
            let isFormData = false;
            const reqHeaders = Object.assign({
                'Referer': currentPanelUrl || url,
                'Accept': '*/*',
                'User-Agent': navigator.userAgent
            }, origHeaders || {});

            // Convert cross-realm FormData/URLSearchParams to native objects
            if (body) {
                const typeName = body.constructor ? body.constructor.name : '';

                if (typeName === 'FormData') {
                    isFormData = true;
                    nativeBody = new FormData();
                    body.forEach((value, key) => {
                        nativeBody.append(key, value);
                    });
                    delete reqHeaders['Content-Type'];
                    delete reqHeaders['content-type'];
                } else if (typeName === 'URLSearchParams') {
                    nativeBody = body.toString();
                    if (!reqHeaders['Content-Type'] && !reqHeaders['content-type']) {
                        reqHeaders['Content-Type'] = 'application/x-www-form-urlencoded; charset=utf-8';
                    }
                }
            }

            try {
                const res = await new Promise((resolve, reject) => {
                    GM_xmlhttpRequest({
                        method: method,
                        url: url,
                        data: nativeBody,
                        anonymous: false,
                        headers: reqHeaders,
                        onload: (r) => resolve({ status: r.status, text: r.responseText }),
                        onerror: (e) => reject(e)
                    });
                });
                iframe.contentWindow.postMessage({
                    type: 'lc-pro-ajax-res',
                    id: id,
                    status: res.status,
                    text: res.text
                }, '*');
            } catch (e) {
                iframe.contentWindow.postMessage({
                    type: 'lc-pro-ajax-res',
                    id: id,
                    status: 500,
                    text: 'Network Error: ' + (e.message || 'Unknown')
                }, '*');
            }
        }

        // Handle Fetch Frame Request from converted frameset
        if (event.data && event.data.type === 'lc-pro-fetch-frame') {
            const { id, url } = event.data;
            try {
                const res = await new Promise((resolve, reject) => {
                    GM_xmlhttpRequest({
                        method: 'GET',
                        url: url,
                        anonymous: false,
                        headers: {
                            'Referer': currentPanelUrl || url,
                            'Accept': 'text/html,*/*',
                            'User-Agent': navigator.userAgent
                        },
                        onload: (r) => resolve({ status: r.status, text: r.responseText }),
                        onerror: (e) => reject(e)
                    });
                });

                const modifiedInnerHtml = modifyHtml(res.text, url);

                iframe.contentWindow.postMessage({
                    type: 'lc-pro-frame-html',
                    id: id,
                    html: modifiedInnerHtml
                }, '*');
            } catch (e) {
                console.error('[LiveChat Pro] Failed to fetch inner frame', e);
            }
        }

        // Handle Navigation from iframe
        if (event.data && event.data.type === 'lc-pro-navigate') {
            openSmartPanel('Navigasi', event.data.url);
        }
    });

